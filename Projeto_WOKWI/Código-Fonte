---("sketch.ino")
#include <WiFi.h>
#include <WebServer.h>

const char* ssid     = "Wokwi-GUEST";
const char* password = "";

WebServer server(80);

const int mq2Pin    = 34;
const int buzzerPin = 27;
const int redLED    = 26;
const int greenLED  = 25;

const int detectionThresholdGas   = 600;
const int detectionThresholdSmoke = 30;
const int buzzerChannel           = 0;

String currentStatus      = "Safe";
int    currentSensorValue = 0;

void handleRoot(){
  String json = "{";
  json += "\"ip\":\"" + WiFi.localIP().toString() + "\",";
  json += "\"sensor\":" + String(currentSensorValue) + ",";
  json += "\"status\":\"" + currentStatus + "\"";
  json += "}";
  server.send(200, "application/json", json);
}

void setup(){
  Serial.begin(115200);

  WiFi.begin(ssid, password);
  int tentativas = 0;
  while(WiFi.status() != WL_CONNECTED && tentativas < 20){
    delay(500);
    Serial.print(".");
    tentativas++;
  }
  if(WiFi.status() == WL_CONNECTED){
    Serial.println("\nWiFi Conectado!");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\nFalha no WiFi! Continuando sem rede...");
  }

  server.on("/", handleRoot);
  server.begin();

  pinMode(redLED,   OUTPUT);
  pinMode(greenLED, OUTPUT);

  ledcAttachChannel(buzzerPin, 1500, 8, buzzerChannel);
}

void loop(){
  server.handleClient();

  currentSensorValue = analogRead(mq2Pin);
  Serial.print("Sensor Value: ");
  Serial.println(currentSensorValue);

  if(currentSensorValue > detectionThresholdSmoke){
    currentStatus = (currentSensorValue > detectionThresholdGas) ? "Gas" : "Smoke";
    Serial.println(currentSensorValue > detectionThresholdGas ? "⚠️ Gas Detected!" : "⚠️ Smoke Detected!");
    digitalWrite(redLED,   HIGH);
    digitalWrite(greenLED, LOW);
    ledcWriteTone(buzzerChannel, 1500);
  } else {
    currentStatus = "Safe";
    Serial.println("Status: Safe");
    digitalWrite(redLED,   LOW);
    digitalWrite(greenLED, HIGH);
    ledcWriteTone(buzzerChannel, 0);
    ledcWrite(buzzerChannel, 0);
  }

  delay(200);
}


